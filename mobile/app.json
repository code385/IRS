{
  "expo": {
    "name": "IRS Timesheet",
    "slug": "irs-timesheet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hashturn.irstimesheet",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.hashturn.irstimesheet"
    },
    "web": {
      "name": "IRS Timesheet",
      "shortName": "IRS",
      "favicon": "./assets/icon.png"
    },
    "updates": {
      "enabled": false
    },
    "extra": {
      "eas": {
        "projectId": "bc8048dd-a97e-4da0-b509-2c449eb75c19"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser"
    ]
  }
}
